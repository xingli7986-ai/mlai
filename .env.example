# Copy this file to `.env` and fill in real values.

# PostgreSQL connection string. Neon, Supabase, or any Postgres provider works.
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=

# NextAuth secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of the deployed app. For local dev use http://localhost:3000
NEXTAUTH_URL=

# Google AI key for Gemini 3 Pro Image Preview (Nano Banana Pro).
# Get one from https://aistudio.google.com/app/apikey
GOOGLE_AI_KEY=your_google_ai_key

# Replicate API token — used by the production-print pipeline (Real-ESRGAN 4x
# super-resolution). Get one from https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Cloudflare R2 for persisting AI-generated images.
# Create an R2 bucket and API token at https://dash.cloudflare.com/?to=/:account/r2
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public URL base for the bucket (r2.dev subdomain or custom domain).
R2_PUBLIC_URL=

# Alipay
# ALIPAY_PRIVATE_KEY: merchant app private key (content only, no BEGIN/END headers)
# ALIPAY_PUBLIC_KEY: Alipay platform public key (NOT the app public key)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
NEXT_PUBLIC_BASE_URL=https://maxlulu-ai-iota.vercel.app

# Aliyun SMS
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_ORDER_PAID_TEMPLATE=
