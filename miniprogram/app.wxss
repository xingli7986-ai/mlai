/* MaxLuLu AI 全局样式 —— 白底 + 粉紫渐变品牌色 */

page {
  background: #ffffff;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
}

/* 去掉小程序 button 默认的外描边 & 灰底 */
button {
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: 1.5;
}
button::after {
  border: none;
}

/* 主色胶囊按钮 */
.btn-primary {
  display: block;
  width: 100%;
  padding: 24rpx 0;
  text-align: center;
  color: #ffffff;
  font-weight: 600;
  font-size: 30rpx;
  background: linear-gradient(90deg, #FF6B9D 0%, #C084FC 100%);
  border-radius: 999rpx;
  box-shadow: 0 12rpx 28rpx -8rpx rgba(192, 132, 252, 0.55);
}

.btn-primary[disabled] {
  opacity: 0.4;
  box-shadow: none;
}

/* 次按钮：白底灰边 */
.btn-secondary {
  display: block;
  width: 100%;
  padding: 22rpx 0;
  text-align: center;
  color: #4b5563;
  font-weight: 500;
  font-size: 28rpx;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 999rpx;
}

/* 紧凑胶囊（用于筛选 / 预设标签） */
.pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 26rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.pill-active {
  background: linear-gradient(90deg, #FF6B9D 0%, #C084FC 100%);
  color: #ffffff;
}

/* 圆角卡片 */
.card {
  background: #ffffff;
  border: 2rpx solid #f3f4f6;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx -12rpx rgba(192, 132, 252, 0.18);
}

/* 渐变文字 */
.grad-text {
  background: linear-gradient(90deg, #FF6B9D 0%, #C084FC 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

/* 品牌 logo 色块 */
.logo {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #C084FC 100%);
}

/* 页面外框 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
  letter-spacing: -0.5rpx;
}

.section-sub {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.divider {
  height: 1rpx;
  background: #f3f4f6;
  margin: 24rpx 0;
}

/* 状态徽章 */
.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
}
.badge-amber { background: #fef3c7; color: #d97706; }
.badge-sky { background: #e0f2fe; color: #0284c7; }
.badge-indigo { background: #e0e7ff; color: #4f46e5; }
.badge-emerald { background: #d1fae5; color: #059669; }
.badge-gray { background: #f3f4f6; color: #6b7280; }

.toast {
  position: fixed;
  top: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(90deg, #FF6B9D 0%, #C084FC 100%);
  color: #ffffff;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  z-index: 999;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(192, 132, 252, 0.6);
}
