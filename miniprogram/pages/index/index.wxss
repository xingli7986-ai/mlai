.page {
  padding: 32rpx 32rpx 64rpx;
}

.hero {
  padding: 48rpx 0 32rpx;
  text-align: center;
}

.badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: linear-gradient(90deg, rgba(255, 107, 157, 0.1) 0%, rgba(192, 132, 252, 0.1) 100%);
  color: #C084FC;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.hero-title {
  margin-top: 28rpx;
  font-size: 62rpx;
  font-weight: 700;
  letter-spacing: -0.8rpx;
  line-height: 1.2;
}

.hero-sub {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #6b7280;
  padding: 0 40rpx;
}

.cta-wrap {
  margin-top: 56rpx;
  padding: 0 32rpx;
}

.login-hint {
  margin-top: 20rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
}

.section {
  margin-top: 56rpx;
}

.section-head {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.section-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.steps {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-card {
  padding: 28rpx;
  background: #ffffff;
  border: 2rpx solid #f3f4f6;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx -8rpx rgba(0, 0, 0, 0.05);
}

.step-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B9D 0%, #C084FC 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.step-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
}

/* Showcase */
.showcase {
  white-space: nowrap;
}

.show-item {
  display: inline-block;
  vertical-align: top;
  width: 300rpx;
  margin-right: 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 2rpx solid #f3f4f6;
  background: #ffffff;
  white-space: normal;
}

.show-img {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.show-tag {
  position: absolute;
  bottom: 14rpx;
  left: 14rpx;
  background: rgba(255, 255, 255, 0.35);
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  backdrop-filter: blur(8rpx);
}

.show-user {
  padding: 16rpx 20rpx 4rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.show-desc {
  padding: 0 20rpx 20rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.slogan {
  margin-top: 80rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
}
