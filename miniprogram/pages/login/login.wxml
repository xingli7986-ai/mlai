<view class="container">
  <view class="hero">
    <view class="logo"></view>
    <view class="title grad-text">MaxLuLu AI</view>
    <view class="subtitle">Fashion For You — 每一朵印花，都由你绽放</view>
  </view>

  <view class="card login-card">
    <block wx:if="{{step === 'phone'}}">
      <view class="label">手机号</view>
      <input
        type="number"
        maxlength="11"
        placeholder="请输入 11 位手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
        class="input"
        focus
      />
      <view wx:if="{{error}}" class="error">{{error}}</view>
      <button
        class="btn-primary next-btn"
        disabled="{{!validPhone}}"
        bindtap="handleNext"
      >获取验证码</button>
    </block>

    <block wx:else>
      <view class="label">验证码</view>
      <input
        type="number"
        maxlength="4"
        placeholder="请输入 4 位验证码"
        value="{{code}}"
        bindinput="onCodeInput"
        class="input input-code"
        focus
      />
      <view class="hint-box">
        MVP 测试阶段，请输入验证码 <text class="hint-strong">1234</text>
      </view>
      <view wx:if="{{error}}" class="error">{{error}}</view>
      <button
        class="btn-primary next-btn"
        disabled="{{code.length !== 4 || loading}}"
        bindtap="handleLogin"
      >{{loading ? '登录中...' : '登录'}}</button>
      <view class="back-btn" bindtap="handleBack">返回修改手机号</view>
    </block>
  </view>

  <view class="slogan grad-text">Fashion For You — 每一朵印花，都由你绽放</view>
</view>
