.page {
  padding: 32rpx 32rpx 96rpx;
}

.presets {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
}

.textarea {
  margin-top: 24rpx;
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.55;
}

.char-count {
  margin-top: 8rpx;
  text-align: right;
  font-size: 22rpx;
  color: #9ca3af;
}

.error-box {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #fef2f2;
  border-radius: 16rpx;
  color: #e11d48;
  font-size: 24rpx;
}

.hint-small {
  margin-top: 14rpx;
  text-align: center;
  font-size: 22rpx;
  color: #9ca3af;
}

.img-grid {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.img-item {
  position: relative;
  aspect-ratio: 3 / 4;
  border-radius: 24rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
}

.img-picked {
  border-color: #C084FC;
  box-shadow: 0 12rpx 28rpx -8rpx rgba(192, 132, 252, 0.45);
}

.img-el {
  width: 100%;
  height: 100%;
}

.img-tag {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
  padding: 4rpx 14rpx;
  background: rgba(0, 0, 0, 0.45);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 999rpx;
}

.img-check {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B9D 0%, #C084FC 100%);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 40rpx;
  text-align: center;
  font-weight: 700;
}

.action-row {
  margin-top: 32rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
}

.type-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.fabric-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.type-card {
  padding: 24rpx;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 24rpx;
}

.type-picked {
  border-color: #C084FC;
  background: linear-gradient(135deg, rgba(255, 107, 157, 0.06) 0%, rgba(192, 132, 252, 0.06) 100%);
  box-shadow: 0 8rpx 24rpx -8rpx rgba(192, 132, 252, 0.35);
}

.type-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.type-desc {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.size-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.size-cell {
  padding: 24rpx 0;
  text-align: center;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 20rpx;
  font-weight: 600;
  color: #4b5563;
}

.size-picked {
  border-color: #C084FC;
  background: linear-gradient(135deg, rgba(255, 107, 157, 0.08) 0%, rgba(192, 132, 252, 0.08) 100%);
  color: #C084FC;
  box-shadow: 0 8rpx 20rpx -8rpx rgba(192, 132, 252, 0.3);
}

.summary {
  margin-top: 32rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255, 107, 157, 0.05) 0%, rgba(192, 132, 252, 0.1) 100%);
}

.summary-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.summary-price {
  margin-top: 8rpx;
  font-size: 56rpx;
  font-weight: 700;
}

.summary-detail {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.submit-btn {
  margin-top: 32rpx;
}
